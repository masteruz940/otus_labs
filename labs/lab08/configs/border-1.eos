hostname border-1
!
service routing protocols model multi-agent
!
ip routing
!
interface Ethernet1
   description blue-to-leaf-3
   no switchport
   ip address 172.31.10.2/30
   no shutdown
!
interface Ethernet2
   description red-to-leaf-3
   no switchport
   ip address 172.31.20.2/30
   no shutdown
!
interface Loopback0
   ip address 172.31.255.1/32
!
router bgp 65300
   router-id 172.31.255.1
   neighbor 172.31.10.1 remote-as 65110
   neighbor 172.31.20.1 remote-as 65120
